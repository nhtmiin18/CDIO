{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "es5",
    "lib": [ "dom", "dom.iterable", "esnext" ],
    "allowJs": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "include": [
      "src"
    ],
    "exclude": [
      "node_modules",
      "server.cjs",
      "server.js"
    ]

  }
}
