{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for Student Profile Application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup": "powershell -Command \"mkdir src, src\\config, src\\controllers, src\\models, src\\routes, src\\middlewares, src\\utils, uploads, uploads\\avatars, uploads\\cvs -Force\"",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force uploads; mkdir uploads, uploads\\avatars, uploads\\cvs -Force\"",
    "seed": "node src/utils/seedData.js",
    "reset": "npm run clean && npm run seed"
  },
  "keywords": [
    "student",
    "profile",
    "backend",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "morgan": "^1.10.1",
    "nodemon": "^3.1.11"
  }
}
